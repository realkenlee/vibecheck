{
  "name": "vibe-check",
  "version": "0.5.0",
  "description": "Know where your AI coding tokens go — local-first analytics for Claude Code & Codex: spend, activities, budget burn-down. Free forever.",
  "license": "MIT",
  "author": "Ken Lee <khflee@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/realkenlee/vibecheck.git"
  },
  "homepage": "https://github.com/realkenlee/vibecheck#readme",
  "bugs": "https://github.com/realkenlee/vibecheck/issues",
  "type": "module",
  "bin": {
    "vibecheck": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc && node dist/cli.js",
    "compile": "tsc && bun build --compile --minify dist/cli.js --outfile vibecheck",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "claude-code",
    "codex",
    "analytics",
    "tokens",
    "ai-coding",
    "usage",
    "local-first",
    "budget",
    "devprod",
    "cost-tracking"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
